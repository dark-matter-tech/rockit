// test_strings.rok — Native codegen test for string operations

fun main(): Unit {
    // String literals
    val hello: String = "hello"
    val world: String = "world"
    println(hello)
    println(world)

    // Concatenation
    val greeting: String = stringConcat(hello, stringConcat(" ", world))
    println(greeting)

    // Length
    println(stringLength(hello))

    // charAt
    println(charAt(hello, 0))
    println(charAt(hello, 4))

    // substring
    println(substring(greeting, 0, 5))
    println(substring(greeting, 6, 11))

    // String comparison
    val a: String = "abc"
    val b: String = "abc"
    val c: String = "xyz"
    if (a == b) { println("eq: pass") } else { println("eq: FAIL") }
    if (a != c) { println("neq: pass") } else { println("neq: FAIL") }

    // startsWith / endsWith
    if (startsWith(greeting, "hello")) { println("starts: pass") } else { println("starts: FAIL") }
    if (endsWith(greeting, "world")) { println("ends: pass") } else { println("ends: FAIL") }

    // indexOf
    println(stringIndexOf(greeting, "world"))

    // trim
    val padded: String = "  hi  "
    println(stringTrim(padded))

    // toString
    println(toString(42))
}
