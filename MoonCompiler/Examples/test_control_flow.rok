// test_control_flow.rok — Native codegen test for control flow

fun abs(n: Int): Int {
    if (n < 0) {
        return 0 - n
    }
    return n
}

fun fib(n: Int): Int {
    if (n <= 1) { return n }
    return fib(n - 1) + fib(n - 2)
}

fun classify(n: Int): String {
    if (n < 0) {
        return "negative"
    } else if (n == 0) {
        return "zero"
    } else {
        return "positive"
    }
}

fun main(): Unit {
    // if/else
    println(classify(-5))
    println(classify(0))
    println(classify(7))

    // abs
    println(abs(-42))
    println(abs(42))

    // while loop — sum 1..10
    var sum: Int = 0
    var i: Int = 1
    while (i <= 10) {
        sum = sum + i
        i = i + 1
    }
    println(sum)

    // Nested loops — multiplication table check
    var product: Int = 0
    var r: Int = 1
    while (r <= 3) {
        var c: Int = 1
        while (c <= 3) {
            product = product + r * c
            c = c + 1
        }
        r = r + 1
    }
    println(product)

    // Boolean logic
    val t: Bool = true
    val f: Bool = false
    if (t && !f) { println("and: pass") } else { println("and: FAIL") }
    if (t || f) { println("or: pass") } else { println("or: FAIL") }
    if (!f) { println("not: pass") } else { println("not: FAIL") }

    // Recursion
    println(fib(10))

    // Comparison operators
    if (3 < 5) { println("lt: pass") } else { println("lt: FAIL") }
    if (5 > 3) { println("gt: pass") } else { println("gt: FAIL") }
    if (3 <= 3) { println("lte: pass") } else { println("lte: FAIL") }
    if (5 >= 5) { println("gte: pass") } else { println("gte: FAIL") }
}
