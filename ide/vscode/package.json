{
  "name": "rockit-lang",
  "displayName": "Rockit Language",
  "description": "Syntax highlighting, LSP support, snippets, and editor support for the Rockit programming language",
  "version": "0.1.0",
  "publisher": "darkmattertech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dark-Matter/moon"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "rockit",
    "rok",
    "dark matter",
    "compiler",
    "language"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:rockit"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rockit",
        "aliases": ["Rockit", "rockit"],
        "extensions": [".rok"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/rockit-light.svg",
          "dark": "./icons/rockit-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "rockit",
        "scopeName": "source.rockit",
        "path": "./syntaxes/rockit.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rockit",
        "path": "./snippets/rockit.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Rockit",
      "properties": {
        "rockit.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Rockit Language Server for diagnostics, completion, hover, and more."
        },
        "rockit.lsp.path": {
          "type": "string",
          "default": "rockit",
          "description": "Path to the rockit binary. Defaults to 'rockit' (must be on PATH)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
