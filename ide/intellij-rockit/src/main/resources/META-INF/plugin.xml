<idea-plugin>
    <id>com.darkmatter.rockit</id>
    <name>Rockit Language Support</name>
    <version>0.1.0</version>
    <vendor email="support@darkmatter.tech" url="https://github.com/Dark-Matter/moon">Dark Matter Tech</vendor>

    <description><![CDATA[
    Syntax highlighting, brace matching, commenting, and Language Server Protocol support for the
    <b>Rockit</b> programming language (<code>.rok</code> files).

    <h3>Features</h3>
    <ul>
        <li>Full syntax highlighting for all 47 keywords and operators</li>
        <li>String interpolation highlighting (<code>$name</code> and <code>${expr}</code>)</li>
        <li>Nestable block comment support</li>
        <li>Brace, bracket, and parenthesis matching</li>
        <li>Line and block comment toggling (Cmd+/ / Ctrl+/)</li>
        <li>Auto-close quotes</li>
        <li>Configurable color scheme (Settings &gt; Editor &gt; Color Scheme &gt; Rockit)</li>
        <li>Error diagnostics (red squiggly lines) via LSP</li>
        <li>Code completion via LSP</li>
        <li>Hover information via LSP</li>
        <li>Go-to-definition via LSP</li>
        <li>Signature help via LSP</li>
        <li>Document symbols via LSP</li>
    </ul>

    <p>LSP features require the <code>rockit</code> CLI to be installed and on your PATH.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="lsp.xml">com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="Rockit"
                implementationClass="com.darkmatter.rockit.RockitFileType"
                fieldName="INSTANCE"
                language="Rockit"
                extensions="rok;rokb"/>

        <lang.syntaxHighlighterFactory
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.darkmatter.rockit.RockitColorSettingsPage"/>

        <lang.commenter
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitCommenter"/>

        <lang.braceMatcher
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitBraceMatcher"/>

        <lang.quoteHandler
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitQuoteHandler"/>

        <lang.parserDefinition
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitParserDefinition"/>

        <lang.foldingBuilder
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitFoldingBuilder"/>

        <lang.psiStructureViewFactory
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitStructureViewFactory"/>

        <codeInsight.lineMarkerProvider
                language="Rockit"
                implementationClass="com.darkmatter.rockit.RockitTestLineMarkerProvider"/>

        <notificationGroup id="Rockit Test Runner"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <!-- Color scheme addons — provide distinct default colors per theme -->
        <additionalTextAttributesScheme scheme="Darcula" file="colorSchemes/RockitDarcula.xml"/>
        <additionalTextAttributesScheme scheme="Default" file="colorSchemes/RockitDefault.xml"/>
    </extensions>
</idea-plugin>
