<list>
    <!-- Rockit Language — Default (light theme) color scheme addon -->

    <!-- Declaration keywords: fun, val, var, class, etc. — blue, bold -->
    <option name="ROCKIT_KEYWORD">
        <value>
            <option name="FOREGROUND" value="0033b3"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Control flow: if, else, for, while, return, etc. — blue, bold -->
    <option name="ROCKIT_CONTROL_KEYWORD">
        <value>
            <option name="FOREGROUND" value="0033b3"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Rockit-specific: view, actor, suspend, concurrent, etc. — purple, bold -->
    <option name="ROCKIT_BUILTIN_KEYWORD">
        <value>
            <option name="FOREGROUND" value="871094"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Boolean literals: true, false — orange/amber, bold -->
    <option name="ROCKIT_BOOLEAN_LITERAL">
        <value>
            <option name="FOREGROUND" value="e57c00"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Null literal — red, bold -->
    <option name="ROCKIT_NULL_LITERAL">
        <value>
            <option name="FOREGROUND" value="c62828"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Optional operators: ?, ?., ?: — dark cyan, bold -->
    <option name="ROCKIT_OPTIONAL_OPERATOR">
        <value>
            <option name="FOREGROUND" value="00838f"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Force unwrap: !! — red, bold -->
    <option name="ROCKIT_FORCE_UNWRAP">
        <value>
            <option name="FOREGROUND" value="c62828"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Boolean-prefixed identifiers: isActive, hasAccess, etc. — amber -->
    <option name="ROCKIT_BOOLEAN_IDENTIFIER">
        <value>
            <option name="FOREGROUND" value="e57c00"/>
        </value>
    </option>

    <!-- Function calls — dark gold -->
    <option name="ROCKIT_FUNCTION_CALL">
        <value>
            <option name="FOREGROUND" value="7a5e2d"/>
        </value>
    </option>

    <!-- Built-in types: String, Int, Bool, List, etc. — dark teal -->
    <option name="ROCKIT_BUILTIN_TYPE">
        <value>
            <option name="FOREGROUND" value="00627a"/>
        </value>
    </option>

    <!-- Built-in functions: println, listOf, etc. — dark teal, italic -->
    <option name="ROCKIT_BUILTIN_FUNCTION">
        <value>
            <option name="FOREGROUND" value="00627a"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- String literals — green -->
    <option name="ROCKIT_STRING">
        <value>
            <option name="FOREGROUND" value="067d17"/>
        </value>
    </option>

    <!-- Escape sequences — dark blue, bold -->
    <option name="ROCKIT_STRING_ESCAPE">
        <value>
            <option name="FOREGROUND" value="0037a6"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- String interpolation — dark blue, bold -->
    <option name="ROCKIT_STRING_INTERPOLATION">
        <value>
            <option name="FOREGROUND" value="0037a6"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Numbers — blue -->
    <option name="ROCKIT_NUMBER">
        <value>
            <option name="FOREGROUND" value="1750eb"/>
        </value>
    </option>

    <!-- Line comments — gray, italic -->
    <option name="ROCKIT_LINE_COMMENT">
        <value>
            <option name="FOREGROUND" value="8c8c8c"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- Block comments — gray, italic -->
    <option name="ROCKIT_BLOCK_COMMENT">
        <value>
            <option name="FOREGROUND" value="8c8c8c"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- Annotations — yellow-brown -->
    <option name="ROCKIT_ANNOTATION">
        <value>
            <option name="FOREGROUND" value="bbb529"/>
        </value>
    </option>

    <!-- Operators — dark gray -->
    <option name="ROCKIT_OPERATOR">
        <value>
            <option name="FOREGROUND" value="436788"/>
        </value>
    </option>
</list>
