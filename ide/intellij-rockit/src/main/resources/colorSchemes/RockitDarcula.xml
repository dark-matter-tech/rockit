<list>
    <!-- Rockit Language — Darcula (dark theme) color scheme addon -->
    <!-- Xcode/Swift-inspired palette for dark backgrounds -->

    <!-- Declaration keywords: fun, val, var, class, etc. — pink -->
    <option name="ROCKIT_KEYWORD">
        <value>
            <option name="FOREGROUND" value="ff7ab2"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Control flow: if, else, for, while, return, etc. — pink -->
    <option name="ROCKIT_CONTROL_KEYWORD">
        <value>
            <option name="FOREGROUND" value="ff7ab2"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Rockit-specific: view, actor, suspend, concurrent, etc. — purple -->
    <option name="ROCKIT_BUILTIN_KEYWORD">
        <value>
            <option name="FOREGROUND" value="b381cf"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Boolean literals: true, false — amber/orange, bold -->
    <option name="ROCKIT_BOOLEAN_LITERAL">
        <value>
            <option name="FOREGROUND" value="ffa030"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Null literal — coral red, bold -->
    <option name="ROCKIT_NULL_LITERAL">
        <value>
            <option name="FOREGROUND" value="ff6b68"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Optional operators: ?, ?., ?: — bright cyan, bold -->
    <option name="ROCKIT_OPTIONAL_OPERATOR">
        <value>
            <option name="FOREGROUND" value="56b6c2"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Force unwrap: !! — coral red, bold -->
    <option name="ROCKIT_FORCE_UNWRAP">
        <value>
            <option name="FOREGROUND" value="ff6b68"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Boolean-prefixed identifiers: isActive, hasAccess, etc. — amber -->
    <option name="ROCKIT_BOOLEAN_IDENTIFIER">
        <value>
            <option name="FOREGROUND" value="ffa030"/>
        </value>
    </option>

    <!-- Optional identifiers: val name: String? — softer cyan -->
    <option name="ROCKIT_OPTIONAL_IDENTIFIER">
        <value>
            <option name="FOREGROUND" value="6bc9d4"/>
        </value>
    </option>

    <!-- Function calls — yellow -->
    <option name="ROCKIT_FUNCTION_CALL">
        <value>
            <option name="FOREGROUND" value="dcdcaa"/>
        </value>
    </option>

    <!-- Built-in types: String, Int, Bool, List, etc. — teal -->
    <option name="ROCKIT_BUILTIN_TYPE">
        <value>
            <option name="FOREGROUND" value="5dd8b4"/>
        </value>
    </option>

    <!-- Built-in functions: println, listOf, etc. — darker teal, italic -->
    <option name="ROCKIT_BUILTIN_FUNCTION">
        <value>
            <option name="FOREGROUND" value="67b7a4"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- String literals — red/salmon -->
    <option name="ROCKIT_STRING">
        <value>
            <option name="FOREGROUND" value="fc6a5d"/>
        </value>
    </option>

    <!-- Escape sequences in strings — golden, bold -->
    <option name="ROCKIT_STRING_ESCAPE">
        <value>
            <option name="FOREGROUND" value="e9b96e"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- String interpolation ($name, ${expr}) — blue, bold -->
    <option name="ROCKIT_STRING_INTERPOLATION">
        <value>
            <option name="FOREGROUND" value="41a1c0"/>
            <option name="FONT_TYPE" value="1"/>
        </value>
    </option>

    <!-- Numbers — yellow/gold -->
    <option name="ROCKIT_NUMBER">
        <value>
            <option name="FOREGROUND" value="d0bf69"/>
        </value>
    </option>

    <!-- Line comments — gray-green, italic -->
    <option name="ROCKIT_LINE_COMMENT">
        <value>
            <option name="FOREGROUND" value="7f8c98"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- Block comments — gray-green, italic -->
    <option name="ROCKIT_BLOCK_COMMENT">
        <value>
            <option name="FOREGROUND" value="7f8c98"/>
            <option name="FONT_TYPE" value="2"/>
        </value>
    </option>

    <!-- Annotations — orange -->
    <option name="ROCKIT_ANNOTATION">
        <value>
            <option name="FOREGROUND" value="ffa14f"/>
        </value>
    </option>

    <!-- Operators — light gray -->
    <option name="ROCKIT_OPERATOR">
        <value>
            <option name="FOREGROUND" value="a9b7c6"/>
        </value>
    </option>
</list>
