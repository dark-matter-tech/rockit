fun main(): Unit {
    val n: Int = 500000
    val arr = listCreate()
    var i: Int = 0
    while (i < n) {
        listAppend(arr, i)
        i = i + 1
    }
    var sum: Int = 0
    i = 0
    while (i < listSize(arr)) {
        sum = sum + toInt(listGet(arr, i))
        i = i + 1
    }
    println(sum)
}
