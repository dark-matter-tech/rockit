// rockit.io.path — Path manipulation utilities
// Pure string manipulation, no additional builtins needed

fun pathJoin(a: String, b: String): String {
    val aLen = stringLength(a)
    val bLen = stringLength(b)
    if (aLen == 0) { return b }
    if (bLen == 0) { return a }

    val aEndsSlash = charCodeAt(a, aLen - 1) == 47     // '/'
    val bStartsSlash = charCodeAt(b, 0) == 47          // '/'

    if (aEndsSlash == true) {
        if (bStartsSlash == true) {
            return stringConcat(a, substring(b, 1, bLen))
        }
        return stringConcat(a, b)
    }
    if (bStartsSlash == true) {
        return stringConcat(a, b)
    }
    return stringConcat(stringConcat(a, "/"), b)
}

fun pathDir(path: String): String {
    val len = stringLength(path)
    if (len == 0) { return "." }

    // Skip trailing slashes to find effective end
    var effectiveEnd: Int = len
    var trimming: Bool = true
    var j: Int = len - 1
    while (j >= 0) {
        if (trimming == true) {
            if (charCodeAt(path, j) == 47) {
                effectiveEnd = j
            } else {
                trimming = false
            }
        }
        j = j - 1
    }
    if (trimming == true) {
        // Entire path is slashes
        return "/"
    }

    // Find last '/' before effectiveEnd (scan forward, keep updating)
    var lastSlash: Int = 0 - 1
    var i: Int = 0
    while (i < effectiveEnd) {
        if (charCodeAt(path, i) == 47) {
            lastSlash = i
        }
        i = i + 1
    }

    if (lastSlash < 0) { return "." }
    if (lastSlash == 0) { return "/" }
    return substring(path, 0, lastSlash)
}

fun pathBase(path: String): String {
    val len = stringLength(path)
    if (len == 0) { return "." }

    // Skip trailing slashes to find effective end
    var effectiveEnd: Int = len
    var trimming: Bool = true
    var j: Int = len - 1
    while (j >= 0) {
        if (trimming == true) {
            if (charCodeAt(path, j) == 47) {
                effectiveEnd = j
            } else {
                trimming = false
            }
        }
        j = j - 1
    }
    if (trimming == true) {
        // Entire path is slashes
        return "/"
    }

    // Find last '/' before effectiveEnd
    var lastSlash: Int = 0 - 1
    var i: Int = 0
    while (i < effectiveEnd) {
        if (charCodeAt(path, i) == 47) {
            lastSlash = i
        }
        i = i + 1
    }

    if (lastSlash < 0) { return substring(path, 0, effectiveEnd) }
    return substring(path, lastSlash + 1, effectiveEnd)
}

fun pathExt(path: String): String {
    val base = pathBase(path)
    val len = stringLength(base)
    var i: Int = len - 1
    while (i > 0) {
        if (charCodeAt(base, i) == 46) {  // '.'
            return substring(base, i, len)
        }
        i = i - 1
    }
    return ""
}

fun pathWithoutExt(path: String): String {
    val ext = pathExt(path)
    val extLen = stringLength(ext)
    if (extLen == 0) { return path }
    val pathLen = stringLength(path)
    return substring(path, 0, pathLen - extLen)
}

fun pathIsAbsolute(path: String): Bool {
    if (stringLength(path) == 0) { return false }
    return charCodeAt(path, 0) == 47  // '/'
}

fun pathNormalize(path: String): String {
    val len = stringLength(path)
    if (len == 0) { return "." }

    val isAbs = charCodeAt(path, 0) == 47

    // Split by '/'
    val parts = listCreate()
    var start: Int = 0
    var i: Int = 0
    while (i <= len) {
        val atEnd = i == len
        val isSlash = if (atEnd) { false } else { charCodeAt(path, i) == 47 }
        if (atEnd == true) {
            if (start < i) {
                listAppend(parts, substring(path, start, i))
            }
            i = i + 1
        } else { if (isSlash == true) {
            if (start < i) {
                listAppend(parts, substring(path, start, i))
            }
            start = i + 1
            i = i + 1
        } else {
            i = i + 1
        } }
    }

    // Process . and ..
    val result = listCreate()
    var k: Int = 0
    while (k < listSize(parts)) {
        val part = toString(listGet(parts, k))
        if (part == ".") {
            // skip
        } else { if (part == "..") {
            if (listSize(result) > 0) {
                val last = toString(listGet(result, listSize(result) - 1))
                if (last != "..") {
                    listRemoveAt(result, listSize(result) - 1)
                } else {
                    listAppend(result, part)
                }
            } else {
                if (isAbs == false) {
                    listAppend(result, part)
                }
            }
        } else {
            listAppend(result, part)
        } }
        k = k + 1
    }

    // Reconstruct
    var res: String = ""
    if (isAbs == true) { res = "/" }
    var m: Int = 0
    while (m < listSize(result)) {
        if (m > 0) { res = stringConcat(res, "/") }
        res = stringConcat(res, toString(listGet(result, m)))
        m = m + 1
    }
    if (stringLength(res) == 0) { return "." }
    return res
}
