// ── String assertions ───────────────────────────────────────────────────

fun assertStringContains(haystack: String, needle: String, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (stringIndexOf(haystack, needle) >= 0) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "\"" + haystack + "\" does not contain \"" + needle + "\""
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (stringIndexOf(haystack, needle) >= 0) { return }
    val msg = "ASSERTION FAILED: \"" + haystack + "\" does not contain \"" + needle + "\""
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

fun assertStartsWith(s: String, prefix: String, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (startsWith(s, prefix)) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "\"" + s + "\" does not start with \"" + prefix + "\""
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (startsWith(s, prefix)) { return }
    val msg = "ASSERTION FAILED: \"" + s + "\" does not start with \"" + prefix + "\""
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

fun assertEndsWith(s: String, suffix: String, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (endsWith(s, suffix)) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "\"" + s + "\" does not end with \"" + suffix + "\""
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (endsWith(s, suffix)) { return }
    val msg = "ASSERTION FAILED: \"" + s + "\" does not end with \"" + suffix + "\""
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

// ── Unconditional failure ───────────────────────────────────────────────

fun fail(message: String = "test failed"): Unit {
    if (__probeRecording == 1) {
        __probeFailed = __probeFailed + 1
        __probeResults = __probeResults + "F:" + message + "\n"
        return
    }
    panic("ASSERTION FAILED: " + message)
}
