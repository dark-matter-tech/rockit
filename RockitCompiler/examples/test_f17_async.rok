// Test: async/await and concurrent block support
// Sequential awaits + concurrent block with multiple awaits + join counter

suspend fun fetchPayload(): String {
    return "network payload"
}

suspend fun processPayload(): String {
    val payload = await fetchPayload()
    return stringConcat("processed: ", payload)
}

suspend fun fetchHeader(): String {
    return "header-ok"
}

suspend fun fetchStatus(): String {
    return "status-200"
}

suspend fun main(): Unit {
    // Sequential awaits (outside concurrent block)
    val result = await processPayload()
    println(result)

    val raw = await fetchPayload()
    println(raw)

    // Concurrent block with multiple awaits
    concurrent {
        val h = await fetchHeader()
        println(h)
        val s = await fetchStatus()
        println(s)
    }

    println("async test complete")
}
