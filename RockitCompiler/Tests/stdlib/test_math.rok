import rockit.test.probe

@Test
fun testSqrt() {
    val a: Double = rockit_math_sqrt(16.0)
    assertTrue(a == 4.0, "sqrt(16) = 4.0")
}

@Test
fun testSinPiOver2() {
    val b: Double = rockit_math_sin(1.5707963267948966)
    val bRounded: Double = rockit_math_round(b)
    assertTrue(bRounded == 1.0, "sin(PI/2) rounds to 1.0")
}

@Test
fun testCosPi() {
    val c: Double = rockit_math_cos(3.141592653589793)
    val cRounded: Double = rockit_math_round(c)
    assertTrue(cRounded == -1.0, "cos(PI) rounds to -1.0")
}

@Test
fun testPow() {
    val d: Double = rockit_math_pow(2.0, 1.0)
    assertTrue(d == 2.0, "pow(2,1) = 2.0")
    val e: Double = rockit_math_pow(2.0, 3.0)
    assertTrue(e == 8.0, "pow(2,3) = 8.0")
}

@Test
fun testFloor() {
    val f: Double = rockit_math_floor(3.7)
    assertTrue(f == 3.0, "floor(3.7) = 3.0")
}

@Test
fun testCeil() {
    val g: Double = rockit_math_ceil(3.2)
    assertTrue(g == 4.0, "ceil(3.2) = 4.0")
}

@Test
fun testRound() {
    val h: Double = rockit_math_round(3.4)
    assertTrue(h == 3.0, "round(3.4) = 3.0")
}
