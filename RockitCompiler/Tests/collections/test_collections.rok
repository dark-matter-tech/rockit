import rockit.test.probe

@Test
fun testListBasics() {
    val list = listCreate()
    listAppend(list, 10)
    listAppend(list, 20)
    listAppend(list, 30)
    assertEquals(3, listSize(list), "list has 3 elements")
    assertEquals(10, listGet(list, 0), "list[0] = 10")
    assertEquals(20, listGet(list, 1), "list[1] = 20")
    assertEquals(30, listGet(list, 2), "list[2] = 30")
}

@Test
fun testListSet() {
    val list = listCreate()
    listAppend(list, 10)
    listAppend(list, 20)
    listAppend(list, 30)
    listSet(list, 1, 99)
    assertEquals(99, listGet(list, 1), "listSet updates index 1")
}

@Test
fun testListContains() {
    val list = listCreate()
    listAppend(list, 10)
    listAppend(list, 99)
    listAppend(list, 30)
    assertTrue(listContains(list, 99), "list contains 99")
    assertFalse(listContains(list, 42), "list does not contain 42")
}

@Test
fun testListIteration() {
    val list = listCreate()
    listAppend(list, 10)
    listAppend(list, 99)
    listAppend(list, 30)
    var i: Int = 0
    var sum: Int = 0
    while (i < listSize(list)) {
        sum = sum + listGet(list, i)
        i = i + 1
    }
    assertEquals(139, sum, "sum of list elements")
}

@Test
fun testMapBasics() {
    val m = mapCreate()
    mapPut(m, "x", 100)
    mapPut(m, "y", 200)
    mapPut(m, "z", 300)
    assertEquals(100, mapGet(m, "x"), "map[x] = 100")
    assertEquals(200, mapGet(m, "y"), "map[y] = 200")
    assertEquals(300, mapGet(m, "z"), "map[z] = 300")
}

@Test
fun testMapKeys() {
    val m = mapCreate()
    mapPut(m, "x", 100)
    mapPut(m, "y", 200)
    mapPut(m, "z", 300)
    val keys = mapKeys(m)
    assertEquals(3, listSize(keys), "map has 3 keys")
}
