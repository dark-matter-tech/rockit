// test_funptr.rok — Test function pointers and C callbacks

extern fun puts(str: Ptr<Byte>): Int
extern fun atexit(func: Ptr<Byte>): Int
extern fun qsort(base: Ptr<Byte>, nmemb: Int, size: Int, compar: Ptr<Byte>): Unit

fun cleanup() {
    puts(cstr("atexit callback called!"))
}

fun compareInts(a: Ptr<Byte>, b: Ptr<Byte>): Int {
    var aVal: Int = 0
    var bVal: Int = 0
    unsafe {
        aVal = a.load()
        bVal = b.load()
    }
    return aVal - bVal
}

fun main() {
    // Test 1: atexit callback (prints after main returns)
    atexit(addressOf(cleanup))

    // Test 2: qsort with function pointer comparator
    val arr = alloc(5)
    unsafe {
        arr.store(50)
        arr.offset(1).store(10)
        arr.offset(2).store(40)
        arr.offset(3).store(20)
        arr.offset(4).store(30)
    }
    qsort(arr, 5, 8, addressOf(compareInts))
    unsafe {
        println(arr.load())
        println(arr.offset(1).load())
        println(arr.offset(2).load())
        println(arr.offset(3).load())
        println(arr.offset(4).load())
    }
    free(arr)

    println("All function pointer tests passed!")
}
