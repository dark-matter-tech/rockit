// Test: val destructuring — val (a, b) = expr

fun makePair(): List {
    val list = listCreate()
    listAppend(list, 10)
    listAppend(list, 20)
    return list
}

fun makeTriple(): List {
    val list = listCreate()
    listAppend(list, 1)
    listAppend(list, 2)
    listAppend(list, 3)
    return list
}

fun main(): Unit {
    // Basic destructuring
    val (a, b) = makePair()
    println(toString(a))
    println(toString(b))

    // Triple destructuring
    val (x, y, z) = makeTriple()
    println(toString(x))
    println(toString(y))
    println(toString(z))

    // Destructure inline list
    val items = listCreate()
    listAppend(items, 100)
    listAppend(items, 200)
    val (first, second) = items
    println(toString(first))
    println(toString(second))

    println("destructure test complete")
}
