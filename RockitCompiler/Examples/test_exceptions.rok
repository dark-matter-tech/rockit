// test_exceptions.rok — Native codegen test for try/catch

fun riskyDiv(a: Int, b: Int): Int {
    if (b == 0) {
        throw "division by zero"
    }
    return a / b
}

fun main(): Unit {
    // Basic try/catch
    try {
        val result = riskyDiv(10, 2)
        println(result)
    } catch (e) {
        println("FAIL: should not catch")
    }

    // Catch an exception
    try {
        val result = riskyDiv(10, 0)
        println("FAIL: should have thrown")
    } catch (e) {
        println("caught: pass")
    }

    // Code after try/catch continues
    println("after try: pass")

    // Nested try/catch
    try {
        try {
            throw "inner"
        } catch (e) {
            println("inner caught: pass")
        }
        println("outer continues: pass")
    } catch (e) {
        println("FAIL: outer should not catch")
    }

    println("done")
}
