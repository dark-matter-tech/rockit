// Test: interface default methods inherited by implementing classes

interface Greeter {
    fun greet(): String {
        return "hello from default"
    }
    fun farewell(): String {
        return "goodbye from default"
    }
}

class FriendlyBot() : Greeter {
    // Does not override greet or farewell — should inherit defaults
}

class CustomBot() : Greeter {
    // Overrides greet, inherits default farewell
    fun greet(): String {
        return "hello from custom"
    }
}

fun main(): Unit {
    val bot1 = FriendlyBot()
    println(bot1.greet())
    println(bot1.farewell())

    val bot2 = CustomBot()
    println(bot2.greet())
    println(bot2.farewell())

    println("interface defaults test complete")
}
