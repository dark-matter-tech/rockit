// test_classes.rok — Native codegen test for data classes

data class Point(x: Int, y: Int)

fun distSquared(p: Point): Int {
    return p.x * p.x + p.y * p.y
}

fun addPoints(a: Point, b: Point): Point {
    return Point(a.x + b.x, a.y + b.y)
}

fun main(): Unit {
    // Create objects
    val p1 = Point(3, 4)
    val p2 = Point(10, 20)

    // Field access
    println(p1.x)
    println(p1.y)
    println(p2.x)
    println(p2.y)

    // Pass to function
    println(distSquared(p1))

    // Return object from function
    val p3 = addPoints(p1, p2)
    println(p3.x)
    println(p3.y)

    // Null check
    val maybeNull: Point? = null
    if (maybeNull == null) {
        println("null: pass")
    } else {
        println("null: FAIL")
    }

    val notNull: Point? = Point(1, 2)
    if (notNull != null) {
        println("not null: pass")
    } else {
        println("not null: FAIL")
    }
}
